# InboxJanitor Environment Configuration
# Copy this file to .env and fill in your values

# BUG-01 FIX: Use a strong random key, never commit the real value
SECRET_KEY=replace-this-with-a-random-64-char-hex-string

# Flask environment: set to 'development' locally, leave unset (or 'production') on Render
FLASK_ENV=development

# Optional: path to credentials.json (default: credentials.json in project root)
# CLIENT_SECRETS_FILE=credentials.json

# Optional: override database (default: local SQLite)
# DATABASE_URL=postgresql://user:password@host/dbname

# Optional: override port (default: 5005)
# PORT=5005
